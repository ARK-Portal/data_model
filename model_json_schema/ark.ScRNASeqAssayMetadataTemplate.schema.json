{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/ark",
  "title": "ark",
  "type": "object",
  "properties": {
    "specimenModality": {
      "enum": [
        "single specimen",
        "unknown",
        "multispecimen"
      ]
    },
    "assay": {
      "type": "array",
      "items": {
        "enum": [
          "CosMX",
          "CITESeq",
          "SNP array",
          "imaging mass cytometry",
          "H&E",
          "imaging mass spectrometry",
          "Xenium",
          "serial IHC",
          "CE-MS",
          "Olink Flex",
          "Olink Target 96",
          "scVDJSeq",
          "Olink Reveal",
          "snATACSeq",
          "snRNASeq",
          "LC-MS/MS",
          "WES",
          "kiloplex",
          "scRNASeq",
          "CyTOF",
          "VDJSeq",
          "SomaScan",
          "GenePS SeqFISH",
          "flow cytometry",
          "feature barcode sequencing",
          "RNASeq",
          "ASAPSeq",
          "multiplexed ELISA",
          "Olink Focus",
          "Visium",
          "WGS",
          "Olink Target 48",
          "NULISA",
          "Olink Explore HT"
        ]
      },
      "maxItems": 34
    },
    "sequencingSaturation": {},
    "inputCellCount": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "sampleProcessingBatch": {},
    "softwareAndVersion": {
      "enum": [
        "Cell Ranger ATAC v1.1.0",
        "BD FACSDiva 8.0.1",
        "Cell Ranger v7.1.0",
        "Cell Ranger v5.0.1",
        "Cell Ranger v7.2.0",
        "Space Ranger 3.0.0",
        "Space Ranger 3.0.1",
        "Cell Ranger v3.0.0",
        "Space Ranger 3.1.3",
        "Cell Ranger v8.0.0",
        "Cell Ranger v5.0.0",
        "Cell Ranger v6.1.0",
        "Cell Ranger v7.0.0",
        "Cell Ranger v3.0.2",
        "Cell Ranger v6.1.1",
        "Space Ranger 3.1.1",
        "Cell Ranger v6.0.2",
        "Cell Ranger v6.1.2",
        "Cell Ranger v3.1.0",
        "Cell Ranger v3.0.1",
        "Cell Ranger v9.0.0",
        "Cell Ranger v6.0.1",
        "Cell Ranger 9.0.1",
        "Cell Ranger v8.0.1",
        "Cell Ranger v4.0.0",
        "Cell Ranger v6.0.0",
        "demuxlet",
        "Space Ranger 3.1.2",
        "Cell Ranger v7.0.1",
        "Space Ranger 3.1.0",
        ""
      ]
    },
    "alignmentReference": {
      "enum": [
        "modified GRCh38",
        "unknown",
        "10x Cell Ranger Human GRCh38 2020-A",
        "vdj_GRCh38_alts_ensembl-4.0.0",
        "GRCh38",
        "10x Cell Ranger Human GRCh38 2024-A"
      ]
    },
    "platform": {
      "type": "array",
      "items": {
        "enum": [
          "BD LSRFortessa",
          "Helios Mass Cytometer",
          "Illumina HiSeq X Ten",
          "Illumina NovaSeq X",
          "BD FACSDiscover S8",
          "Chromium Next GEM Chip Q",
          "Cytek Aurora",
          "none",
          "Visium CytAssist",
          "Chromium Xo",
          "Xenium",
          "Hyperion",
          "BD FACSDiscover A8",
          "Cytek Aurora Evo",
          "Spatial Genomics Gene Positioning System",
          "Thermo Fisher Attune NxT",
          "BD FACSLyric Clinical",
          "Illumina HiSeq 2500",
          "unknown",
          "Chromium X",
          "GEM-X Flex Gene Expression Chip",
          "Chromium Next GEM Chip H",
          "Chromium iX",
          "Thermo Fisher Attune Xenith",
          "Sony MA900",
          "Not Applicable",
          "Chromium GEM-X Single Cell 3' Chip v4",
          "Illumina NextSeq 500",
          "Chromium Next GEM Chip K",
          "Olink Signature Q100",
          "Chromium Controller",
          "Fluidigm BioMark",
          "Thermo Fisher Attune CytPix",
          "Illumina NovaSeq 6000",
          "GEM-X OCM 5' Chip",
          "BD FACSAria III",
          "BD FACSAria Fusion cell sorter",
          "BD FACSCanto II",
          "BD FACSMelody",
          "CyTOF XT",
          "BD FACSCanto",
          "Chromium Next GEM Chip M",
          "Chromium Next GEM Chip G",
          "BD FACSymphony S6"
        ]
      },
      "maxItems": 44
    },
    "dataCollectionBatch": {},
    "totalReads": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "nucleicAcidSource": {
      "type": "array",
      "items": {
        "enum": [
          "rRNA-depleted RNA",
          "BCR mRNA",
          "poly(A) RNA",
          "intracellular protein feature barcode",
          "gDNA",
          "multiplexing oligo",
          "Tn5-accessible gDNA",
          "surface protein feature barcode",
          "CRISPR protospacer feature barcode",
          "TCR mRNA",
          "antigen capture barcode",
          "globin-depleted RNA"
        ]
      },
      "maxItems": 12
    },
    "libraryPrepMethod": {
      "enum": [
        "TruSeq Stranded mRNA",
        "Nextera XT DNA",
        "Fluidigm C1 HT",
        "10x Chromium GEM-X Single Cell 5' v3",
        "10x Chromium Next GEM Single Cell 5' v2",
        "10x Chromium Next GEM Single Cell ATAC v2",
        "Takara Human BCR profiling for Illumina",
        "custom DASH-treatment",
        "SMART-Seq Human BCR with UMI",
        "in-house library prep",
        "10x Chromium Next GEM Single Cell 3' 3.1",
        "Takara Human scTCR profiling for Illumina",
        "SMART-Seq v4 Ultra Low Input RNA",
        "Takara Human TCRv2 profiling for Illumina",
        "SMARTer Stranded Total RNA v2",
        "NEBNext Ultra II Directional RNA Library",
        "CEL-Seq2",
        "Nextera XT",
        "10x GEM-X Flex Gene Expression Human",
        "10x Chromium Fixed RNA Human Transcriptome",
        "10x Chromium Single Cell Human BCR",
        "NEBNext Human Immune Sequencing Kit",
        "10x Chromium Single Cell Human TCR",
        "Takara Human TCR profiling for Illumina",
        "10x GEM-X Universal 5' Gene Expression v3",
        "QIAseq miRNA Library",
        "10x Chromium GEM-X Single Cell 3' v4",
        "Chromium Next GEM Single Cell ATAC v1.1",
        "SMART-Seq Human TCR with UMI",
        "10x Chromium Next GEM Single Cell 5' v1.1",
        "10x Chromium Next GEM Single Cell 3'"
      ]
    },
    "Component": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "percentCellViability": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "biospecimenID": {},
    "libraryID": {},
    "10xProbeSetReference": {
      "enum": [
        "Flex Human Transcriptome Probe Set v1.0.1",
        "Visium Human Transcriptome v2",
        "custom probe set",
        "Visium Human Transcriptome v1",
        "Flex Human Transcriptome Probe Set v1.1.0",
        ""
      ]
    }
  },
  "required": [
    "specimenModality",
    "assay",
    "inputCellCount",
    "alignmentReference",
    "platform",
    "totalReads",
    "nucleicAcidSource",
    "libraryPrepMethod",
    "Component",
    "percentCellViability"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "specimenModality": {
            "enum": [
              "single specimen"
            ]
          }
        },
        "required": [
          "specimenModality"
        ]
      },
      "then": {
        "properties": {
          "biospecimenID": {
            "not": {
              "type": "null"
            },
            "minLength": 1
          }
        },
        "required": [
          "biospecimenID"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "specimenModality": {
            "enum": [
              "multispecimen"
            ]
          }
        },
        "required": [
          "specimenModality"
        ]
      },
      "then": {
        "properties": {
          "libraryID": {
            "not": {
              "type": "null"
            },
            "minLength": 1
          }
        },
        "required": [
          "libraryID"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "libraryPrepMethod": {
            "enum": [
              "10x GEM-X Flex Gene Expression Human"
            ]
          }
        },
        "required": [
          "libraryPrepMethod"
        ]
      },
      "then": {
        "properties": {
          "10xProbeSetReference": {
            "enum": [
              "Flex Human Transcriptome Probe Set v1.0.1",
              "Visium Human Transcriptome v2",
              "custom probe set",
              "Visium Human Transcriptome v1",
              "Flex Human Transcriptome Probe Set v1.1.0"
            ]
          }
        },
        "required": [
          "10xProbeSetReference"
        ]
      }
    }
  ]
}