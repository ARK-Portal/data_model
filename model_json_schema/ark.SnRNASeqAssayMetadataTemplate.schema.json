    "assay": {
      "type": "array",
      "items": {
        "enum": [
          "imaging mass spectrometry",
          "imaging mass cytometry",
          "snRNASeq",
          "Olink Target 96",
          "Olink Explore HT",
          "RNASeq",
          "Visium",
          "scVDJSeq",
          "multiplexed ELISA",
          "GenePS SeqFISH",
          "Olink Target 48",
          "SomaScan",
          "CITESeq",
