{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/ark",
  "title": "ark",
  "type": "object",
  "properties": {
    "dataCollectionBatch": {},
    "percentCellViability": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "softwareAndVersion": {
      "enum": [
        "Cell Ranger v9.0.0",
        "Cell Ranger v6.0.1",
        "Cell Ranger v7.1.0",
        "Cell Ranger ATAC v1.1.0",
