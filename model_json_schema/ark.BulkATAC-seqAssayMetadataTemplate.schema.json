      },
      "maxItems": 12
    },
    "Component": {
      "not": {
        "type": "null"
      },
      "minLength": 1
    },
    "sampleProcessingBatch": {},
    "assay": {
      "type": "array",
      "items": {
        "enum": [
          "Xenium",
          "snRNASeq",
          "Visium",
          "WGS",
