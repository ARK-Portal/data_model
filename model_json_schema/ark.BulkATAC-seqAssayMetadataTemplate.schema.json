    },
    "specimenModality": {
      "enum": [
        "unknown",
        "single specimen",
        "multispecimen"
      ]
    },
    "softwareAndVersion": {
      "enum": [
        "Cell Ranger v6.0.1",
        "Space Ranger 3.1.0",
        "Cell Ranger v5.0.1",
        "Cell Ranger v9.0.0",
        "Cell Ranger v6.0.0",
